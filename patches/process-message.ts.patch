+/** Check if message has a voice item (any voice, with or without local path). */
+function _hasVoiceItem(full: any): boolean {
+  if (!full?.item_list) return false;
+  for (const item of full.item_list) {
+    if (item?.voice_item) return true;
+  }
+  return false;
+}
